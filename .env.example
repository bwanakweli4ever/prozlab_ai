# Mail (Mailgun SMTP)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@your-domain.example
SMTP_PASSWORD=your-mailgun-smtp-password
EMAIL_FROM=noreply@your-domain.example
MAIL_SUPPORT=support@your-domain.example

# Database
DB_DIALECT=mysql
DB_HOST=localhost
DB_PORT=3306
DB_NAME=prozlab_db
DB_USER=root
DB_PASSWORD=change_me

# API
SECRET_KEY=change_me
API_V1_PREFIX=/api/v1
ENFORCE_EMAIL_VERIFICATION=true

# Mailtrap Send API (recommended)
MAILTRAP_APIKEY=your_mailtrap_api_token
MAILTRAP_FROM_EMAIL=noreply@your-domain.example
MAILTRAP_FROM_NAME=ProzLab Team
MAILTRAP_REPLY_EMAIL=talents@your-domain.example
MAILTRAP_REPLY_NAME=Reply
